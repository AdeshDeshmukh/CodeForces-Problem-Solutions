        if (tn % i == 0) {
            ll cc = 0;
            while (tn % i == 0) {
                cc++;
                tn /= i;
            }
            if (cc % 2 != 0) s *= i;
        }
    }
 
    if (tn > 1) {
        ll roo = tn;
        ll rr = sqrt(roo); 
        if (rr * rr != roo) {
            s *= roo;
        }
    }
 
    ll mss = n / s;
    ll m = sqrt(mss); 
    
    ll q = m + 1;
    ll x = s * q * q;
 
    cout << x << endl ;
}
 
 
 
 
